# App ID y Secret de la app de Meta (developers.facebook.com), producto "Instagram" con Instagram Login
IG_APP_ID=
IG_APP_SECRET=

# Debe coincidir exactamente con el Redirect URI configurado en el dashboard de la app de Meta
IG_REDIRECT_URI=https://tu-dominio.vercel.app/api/auth/instagram/callback

# String secreto inventado por nosotros — se usa para validar el handshake de webhooks
IG_WEBHOOK_VERIFY_TOKEN=

# URL pública del frontend, a donde redirige el callback de OAuth después de conectar
APP_URL=https://tu-dominio.vercel.app

# Inyectadas automáticamente por Vercel al linkear la integración de KV (Upstash Redis) — no completar a mano
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Usuario y contraseña para entrar al panel
APP_LOGIN_USER=
APP_LOGIN_PASSWORD=

# String aleatorio largo e inventado por nosotros, usado para firmar la cookie de sesión (ej: openssl rand -hex 32)
APP_SESSION_SECRET=
